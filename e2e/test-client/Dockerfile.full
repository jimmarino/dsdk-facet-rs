# Multi-stage Dockerfile for vault-test (builds from source for Linux)
# Build from workspace root: docker build -f e2e/test-client/Dockerfile.full -t vault-test:local .

FROM --platform=linux/amd64 rust:bookworm AS builder

# Install build dependencies
RUN apt-get update && \
    apt-get install -y cmake && \
    rm -rf /var/lib/apt/lists/*

WORKDIR /build

# Copy workspace structure
COPY facet-rs/Cargo.toml facet-rs/Cargo.lock ./
COPY facet-rs/crates ./crates
COPY facet-rs/e2e ./e2e
COPY facet-rs/siglet ./siglet

# Copy dataplane-sdk-rust dependency
COPY dataplane-sdk-rust /build/dataplane-sdk-rust

# Build the vault-test binary
RUN cargo build --release --bin vault-test --package vault-e2e-test-client

# Runtime stage - use Debian to match build environment
FROM --platform=linux/amd64 debian:bookworm-slim

# Copy the binary from builder
COPY --from=builder /build/target/release/vault-test /usr/local/bin/vault-test

# Make it executable
RUN chmod +x /usr/local/bin/vault-test

# Run the test binary
ENTRYPOINT ["/usr/local/bin/vault-test"]
